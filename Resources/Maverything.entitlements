<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Intentionally NOT sandboxed: whole-disk indexing is incompatible with
         App Sandbox. Full Disk Access is granted by the user via System Settings.
         No com.apple.security.cs.* opt-outs are needed merely to READ files. -->
</dict>
</plist>
